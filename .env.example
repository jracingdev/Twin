# TWIN Platform — copy to .env (raiz) ou apps/api/.env
# Local Windows: docs/deployment/local-windows.md
# Produção aaPanel: docs/deployment/aapanel.md + infra/aapanel/env.production.snippet
# Produção Docker: docs/deployment/vps-quickstart.md

APP_NAME=TWIN
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

# Produção (ex.: twin.app.br / api.twin.app.br)
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.twin.app.br
# FRONTEND_URL=https://twin.app.br
# SESSION_DOMAIN=.twin.app.br

# --- Banco de dados (MySQL recomendado para produção) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=twin_landlord
DB_USERNAME=twin
DB_PASSWORD=

# SQLite (apenas dev rápido — comente MySQL acima e use):
# DB_CONNECTION=sqlite
# DB_DATABASE=database/twin.sqlite

# Guia completo MySQL no servidor: docs/deployment/mysql-server.md
# Scripts: scripts/mysql/01-create-landlord.sql + scripts/mysql/bootstrap.ps1

QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# AI Engine — AI_ENGINE_SECRET must match on Laravel (apps/api) and AI engine (apps/ai-engine)
# Dev/Docker: porta 8000 | aaPanel produção: http://127.0.0.1:8100 (interno)
AI_ENGINE_URL=http://127.0.0.1:8000
AI_ENGINE_SECRET=local-dev-secret-change-in-prod
AI_ENGINE_TRAIN_TIMEOUT=30
LARAVEL_API_URL=http://127.0.0.1:8080
# Pinecone — vetores/RAG no motor IA (apps/ai-engine). Sem chave, o motor usa fallback local.
PINECONE_API_KEY=
PINECONE_INDEX=twin-integrated

# OpenAI — embeddings e LLM no motor IA. Sem chave, respostas e ingest usam modo demo/fallback.
OPENAI_API_KEY=

# S3 / MinIO
AWS_ACCESS_KEY_ID=twin
AWS_SECRET_ACCESS_KEY=twin_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=twin-imports
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Stripe (test mode: pk_test_ / sk_test_ do dashboard Stripe)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Cadastro público (false = apenas admin cria usuários)
TWIN_REGISTRATION_ENABLED=false
TWIN_DEFAULT_RETENTION_DAYS=365

# Frontend (Next.js — apps/web; build usa apps/web/.env.production.local)
FRONTEND_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080/api/v1
NEXT_PUBLIC_AI_ENGINE_URL=http://127.0.0.1:8000
# Produção aaPanel:
# NEXT_PUBLIC_API_URL=https://api.twin.app.br/api/v1
# NEXT_PUBLIC_AI_ENGINE_URL=https://twin.app.br/ai-engine

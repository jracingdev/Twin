# =============================================================================
# TWIN — variáveis de produção (aaPanel / twin.app.br)
# Copie seções para os arquivos indicados. NÃO commite valores reais.
# Guia: docs/deployment/aapanel.md
# =============================================================================

# --- apps/api/.env (Laravel) ---
APP_NAME=TWIN
APP_ENV=production
APP_KEY=base64:GERE_COM_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://api.twin.app.br

FRONTEND_URL=https://twin.app.br
CORS_ALLOWED_ORIGINS=https://twin.app.br
SESSION_DOMAIN=.twin.app.br

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=twin_landlord
DB_USERNAME=twin
DB_PASSWORD=@TWIN_DB_PASSWORD@

QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

REDIS_HOST=127.0.0.1
# aaPanel Redis quase sempre tem senha — copie do painel (App Store → Redis)
REDIS_PASSWORD=
REDIS_PORT=6379

# Motor IA — apenas rede interna do servidor (uvicorn na porta 8100)
AI_ENGINE_URL=http://127.0.0.1:8100
AI_ENGINE_SECRET=@TWIN_INTERNAL_SECRET@
AI_ENGINE_TRAIN_TIMEOUT=30
LARAVEL_API_URL=https://api.twin.app.br

OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=twin-integrated

# S3 — use bucket real (AWS, Cloudflare R2, MinIO local) ou local para MVP
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=twin-imports
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

TWIN_REGISTRATION_ENABLED=false
TWIN_DEFAULT_RETENTION_DAYS=365

# --- apps/ai-engine/.env (FastAPI + Celery) ---
# REDIS_URL=redis://127.0.0.1:6379/0
# AI_ENGINE_SECRET=@TWIN_INTERNAL_SECRET@   # igual à API
# LARAVEL_API_URL=https://api.twin.app.br
# OPENAI_API_KEY=
# PINECONE_API_KEY=
# PINECONE_INDEX=twin-integrated
# LLM_PROVIDER=openai
# CELERY_INGEST=true

# --- apps/web/.env.production.local (build Next.js) ---
# NEXT_PUBLIC_API_URL=https://api.twin.app.br/api/v1
# Proxy nginx expõe /ai-engine/ → 127.0.0.1:8100 (apenas /health no browser)
# NEXT_PUBLIC_AI_ENGINE_URL=https://twin.app.br/ai-engine
